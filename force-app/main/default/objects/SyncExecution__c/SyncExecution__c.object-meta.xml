<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Execution log for an ErpSync synchronization run.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>true</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Sync Execution</label>
    <nameField>
        <displayFormat>SYNC-{000000}</displayFormat>
        <label>Sync Execution Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Sync Executions</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
